{
  "name": "playvision-report",
  "version": "1.0.2",
  "description": "AI-powered HTML reporter for Playwright with intelligent error analysis",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "postbuild": "node -e \"const fs=require('fs'); if(fs.existsSync('src/html/report-ui/dist')) { fs.mkdirSync('dist/html/report-ui/dist', {recursive:true}); fs.cpSync('src/html/report-ui/dist', 'dist/html/report-ui/dist', {recursive:true}); }\"",
    "dev": "tsc --watch",
    "test": "npm run build && cd test-project && npx playwright test",
    "clean": "rimraf dist"
  },
  "keywords": [
    "playwright",
    "reporter",
    "testing",
    "ai",
    "html-report",
    "test-automation"
  ],
  "author": {
    "name": "Vignesh s",
    "url": "https://github.com/Vignesh8205"
  },
  "license": "MIT",
  "files": [
    "dist/**/*",
    "src/html/report-ui/dist/**/*",
    "README.md"
  ],
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/exceljs": "^0.5.3",
    "@types/node": "^24.10.1",
    "semantic-release": "^25.0.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.0",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0"
  }
}
